---
const shots = [
  { src: '/images/case-front.jpg',    label: 'The face',  note: 'A grille of small hexagons, milled one pass at a time. The case breathes through it without a single fan begging for help.' },
  { src: '/images/case-back.jpg',     label: 'The back',  note: 'A standard ITX I/O cut-out, a clean PSU window, and nothing else. The kind of back you don\'t mind seeing.' },
  { src: '/images/case-backside.jpg', label: 'The grain', note: 'Look at the side and you can count the layers — every laminate of birch, stacked honest, no veneer hiding anything.' },
];
---
<section id="gallery" class="py-28 md:py-40 bg-brand-walnut-dark">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="max-w-2xl mb-16">
      <span class="text-brand-gold text-xs tracking-[0.32em] uppercase">Up close</span>
      <h2 class="font-display text-4xl md:text-5xl mt-4 leading-tight">
        Six sides.<br/>
        <span class="italic text-brand-gold">Nothing to hide.</span>
      </h2>
      <p class="text-brand-cream/65 text-lg mt-6 leading-relaxed font-light">
        A case earns its keep from every angle. Front, back, profile — there's no "good side" you're meant to point at the wall.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 md:gap-8">
      {shots.map((s) => (
        <figure class="group relative">
          <div class="aspect-[4/5] rounded-2xl overflow-hidden border border-brand-gold/10 bg-brand-walnut-dark">
            <img
              src={s.src}
              alt={`Timbrcase — ${s.label}`}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]"
            />
          </div>
          <figcaption class="mt-5">
            <div class="text-brand-gold text-xs tracking-[0.3em] uppercase">{s.label}</div>
            <p class="text-brand-cream/60 text-sm mt-2 leading-relaxed font-light">{s.note}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

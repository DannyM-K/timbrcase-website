---
const shots = [
  { src: '/images/20260508_114435.webp', label: 'The face',         note: 'A hidden power LED that only shines through the wood when the computer is on. In the same spot, the wood itself becomes the button — a soft press, a quiet click, and your computer wakes up.' },
  { src: '/images/20260501_184907.webp', label: 'The side I',       note: 'A grille of small hexagons, laser-cut with high precision — made for the look as much as for the build. It lets your computer breathe easy and stay cool.' },
  { src: '/images/20260501_184916.webp', label: 'The side II',      note: 'One side wears the full honeycomb. The other keeps just a single line of hexagons along the top — enough to release the heat that gathers up there — while the rest stays a clean, open plane of wood, alive with its natural marks.' },
  { src: '/images/20260501_184929.webp', label: 'The back',         note: 'A clean, standard ITX I/O cut-out and a single opening for the PicoPSU. The wood is left thicker around it, so plugging the power cable in and out always feels solid.' },
  { src: '/images/case-backside.webp',   label: 'Around the case',  note: 'Look around the case and you can count every layer — each laminate of birch, bonded with a natural wood glue, finished to feel like one quiet, continuous piece of timber.' },
];
---
<section id="gallery" class="py-28 md:py-40 bg-brand-walnut-dark">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="max-w-2xl mb-16">
      <span class="text-brand-gold text-xs tracking-[0.32em] uppercase">Looking closer</span>
      <h2 class="font-display text-4xl md:text-5xl mt-4 leading-tight">
        Six sides.<br/>
        <span class="italic text-brand-gold">Nothing to hide.</span>
      </h2>
      <p class="text-brand-cream/65 text-lg mt-6 leading-relaxed font-light">
        A case earns its keep from every angle. Front, back, profile — there's no "good side" you're meant to point at the wall.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-6 md:gap-8">
      {shots.map((s) => (
        <figure class="group relative">
          <div class="aspect-[4/5] rounded-2xl overflow-hidden border border-brand-gold/10 bg-brand-walnut-dark">
            <img
              src={s.src}
              alt={`TIMBRCase — ${s.label}`}
              loading="lazy"
              data-lightbox
              class="w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]"
            />
          </div>
          <figcaption class="mt-5">
            <div class="text-brand-gold text-xs tracking-[0.3em] uppercase">{s.label}</div>
            <p class="text-brand-cream/60 text-sm mt-2 leading-relaxed font-light">{s.note}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

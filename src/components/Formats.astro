---
const formats = [
  {
    name: 'Mini-ITX',
    status: 'available',
    headline: 'Available now',
    blurb: 'The size we build first, and the one we keep coming back to. Small enough to live on a shelf, big enough for a real GPU. Three layouts to choose from: Minimalist, with SSD holder, or SSD + GPU.',
    specs: ['Mini-ITX board (170 × 170 mm)', 'PicoPSU powered', 'Hidden power LED & wooden button', 'Laser-cut hexagon airflow', 'High-quality multiplex birch'],
    cta: 'Choose your Timbrcase',
    href: '#reserve',
    image: '/images/mini-itx-card.jpg',
  },
  {
    name: 'Nano-ITX',
    status: 'request',
    headline: 'On request',
    blurb: 'The smallest of the family. Built around a Nano-ITX board with an APU or low-power CPU — no discrete GPU. Compact, silent, and perfectly suited for a tidy desk or a quiet living room.',
    specs: ['Nano-ITX board (120 × 120 mm)', 'APU or low-power CPU', 'PicoPSU powered', 'Silent, fanless-friendly layout'],
    cta: 'Request a build',
    href: '#reserve',
  },
  {
    name: 'ATX',
    status: 'request',
    headline: 'Custom commission',
    blurb: 'For the bigger builds — water cooling, room for any graphics card no matter the size, mounts for radiators, a separate chamber for the PSU and clean cable management, even a glass front if you want one. Built to the same standard as any high-end metal case — only in wood. ATX builds take more time: plan with 2–3 months so we can hold the quality your case deserves.',
    specs: ['ATX or Micro-ATX board', 'Full ATX power supply, separate PSU chamber', 'Any GPU, any size', 'Water-cooling & radiator mounts', 'Optional glass front', 'Build time: 2–3 months'],
    cta: 'Request a build',
    href: '#reserve',
  },
];
---
<section id="formats" class="py-28 md:py-40 wood-texture relative">
  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <div class="max-w-2xl mb-16">
      <span class="text-brand-gold text-xs tracking-[0.32em] uppercase">Three sizes · 5 Formats</span>
      <h2 class="font-display text-4xl md:text-5xl mt-4 leading-tight">
        Built around<br/>
        <span class="italic"><span class="text-brand-cream">your hardware,</span><br/><span class="text-brand-gold">not the other way around.</span></span>
      </h2>
      <p class="text-brand-cream/65 text-lg mt-6 leading-relaxed font-light">
        The first run is ITX — the prototype shown in the photos has since been refined, and you'll receive a perfected version of the case you see. If your build needs more room, or much less, write me and we'll figure it out together.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {formats.map((f) => (
        <div class:list={[
          'rounded-3xl p-7 md:p-8 border bg-brand-walnut-dark/60 backdrop-blur-sm transition-colors',
          f.status === 'available' ? 'border-brand-gold/60 ring-1 ring-brand-gold/30' : 'border-brand-cream/10 hover:border-brand-gold/40',
        ]}>
          <div class="flex items-baseline justify-between mb-3">
            <h3 class="font-display text-3xl">{f.name}</h3>
            <span class:list={[
              'text-[10px] tracking-[0.25em] uppercase px-2.5 py-1 rounded-full',
              f.status === 'available' ? 'bg-brand-gold text-brand-walnut-dark font-semibold' : 'border border-brand-cream/25 text-brand-cream/70',
            ]}>{f.headline}</span>
          </div>
          <p class="text-brand-cream/65 text-sm leading-relaxed mb-6 font-light">{f.blurb}</p>
          <ul class="space-y-2 mb-7 text-sm text-brand-cream/75">
            {f.specs.map((s) => (
              <li class="flex gap-2.5">
                <span class="text-brand-gold mt-1 shrink-0">▸</span>
                <span>{s}</span>
              </li>
            ))}
          </ul>
          <a
            href={f.href}
            class:list={[
              'inline-flex items-center gap-2 text-sm font-semibold rounded-full px-5 py-2.5 transition-colors',
              f.status === 'available'
                ? 'bg-brand-purple text-brand-cream hover:opacity-90'
                : 'border border-brand-cream/25 text-brand-cream hover:border-brand-gold/60 hover:text-brand-gold',
            ]}
          >
            {f.cta} →
          </a>
          {f.image && (
            <div class="mt-7 rounded-2xl overflow-hidden border border-brand-gold/15 bg-brand-walnut-dark">
              <img
                src={f.image}
                alt={`${f.name} Timbrcase`}
                class="w-full h-auto block"
                loading="lazy"
              />
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

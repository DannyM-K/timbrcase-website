---
const steps = [
  {
    n: '01',
    t: 'Choosing the wood',
    d: 'We work closely with a traditional family-run timber supplier who provides us with the highest-quality multiplex birch plywood — and other European woods on request. All sourced from Europe. Every Timbrcase is built from high-quality multiplex birch.',
  },
  {
    n: '02',
    t: 'Cut',
    d: 'Each panel is laser-cut to a precise pattern and inspected by hand. Any natural marks in the wood are kept where they add to the character of the case, never take away from it.',
  },
  {
    n: '03',
    t: 'Bond',
    d: 'The pieces are carefully glued together with a natural timber glue, sanded smooth, and finished to your wish — natural, oiled, or stained. More elaborate finishes are available on request and may add to the cost.',
  },
  {
    n: '04',
    t: 'Mounting',
    d: 'The mainboard standoffs, the power LED, and the wooden power button — wired and ready to plug straight into your mainboard — are mounted by hand.',
  },
  {
    n: '05',
    t: 'Final inspection',
    d: 'Every case goes through a final inspection and test to make sure everything runs smoothly and the ITX board sits exactly where it should.',
  },
];
---
<section id="craft" class="relative py-28 md:py-40 overflow-hidden bg-brand-walnut-dark">
  <img
    src="/images/20260507_125614.jpg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover opacity-25 scale-110 blur-[2px]"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-brand-walnut-dark via-brand-walnut-dark/85 to-brand-walnut-dark"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid lg:grid-cols-12 gap-14 items-start">
      <div class="lg:col-span-5">
        <span class="text-brand-gold text-xs tracking-[0.32em] uppercase">How it's made</span>
        <h2 class="font-display text-4xl md:text-5xl mt-4 mb-8 leading-tight">
          Five steps.<br/>
          <span class="italic text-brand-gold">Built by a small circle.</span>
        </h2>
        <p class="text-brand-cream/75 text-lg leading-relaxed font-light mb-5">
          The wood comes from a family-run timber supplier in Europe, and from there everything happens in one small workshop in Germany, close to the river Rhine — cut, bonded, sanded, finished, mounted, and tested by hand before it leaves.
        </p>
        <p class="text-brand-cream/65 text-base leading-relaxed font-light mb-5">
          Built in Germany, from wood sourced across Europe — together, that makes every case <span class="text-brand-gold">100 % made in Europe</span>.
        </p>
        <p class="text-brand-cream/65 text-base leading-relaxed font-light italic">
          Every case is a small piece of design art. Because each panel of wood has its own grain, its own flaws, its own light — no two Timbrcases will ever be exactly the same. Yours will only ever be yours.
        </p>
        <div class="mt-10 rounded-2xl overflow-hidden border border-brand-gold/10 bg-brand-walnut-dark">
          <img src="/images/20260507_125614.jpg" alt="Multiplex birch lamination, close-up" class="w-full h-auto block" loading="lazy"/>
        </div>
      </div>

      <div class="lg:col-span-7 grid sm:grid-cols-2 gap-6">
        {steps.map((s) => (
          <div class="border-t border-brand-gold/25 pt-6 pr-2">
            <div class="text-brand-gold/70 font-display text-sm mb-3">{s.n}</div>
            <h3 class="font-display text-2xl mb-3">{s.t}</h3>
            <p class="text-brand-cream/65 text-sm leading-relaxed font-light">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

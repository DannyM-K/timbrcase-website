---
const steps = [
  { n: '01', t: 'Pick the wood',  d: 'Baltic birch plywood, sustainably sourced, hand-graded. Every panel is checked for voids before it goes near the machine.' },
  { n: '02', t: 'Mill it honest', d: 'CNC-routed on a 3-axis. Each hexagon, each I/O cut, each screw seat — held to 0.05 mm. Then deburred by hand.' },
  { n: '03', t: 'Sand & breathe', d: 'Three grits, dust extraction, a cooling-down day. The case rests overnight before finishing.' },
  { n: '04', t: 'Oil & assemble', d: 'Food-safe hardwax oil — no plastic film, no shine. The lamination edge stays alive. Then glued, clamped and screwed in our shop.' },
];
---
<section id="craft" class="relative py-28 md:py-40 overflow-hidden bg-brand-walnut-dark">
  <!-- Detail image as full-bleed background, blurred -->
  <img
    src="/images/detail.jpg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover opacity-25 scale-110 blur-[2px]"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-brand-walnut-dark via-brand-walnut-dark/85 to-brand-walnut-dark"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid lg:grid-cols-12 gap-14 items-start">
      <div class="lg:col-span-5">
        <span class="text-brand-gold text-xs tracking-[0.32em] uppercase">The Craft</span>
        <h2 class="font-display text-4xl md:text-5xl mt-4 mb-8 leading-tight">
          Four steps.<br/>
          <span class="italic text-brand-gold">One pair of hands.</span>
        </h2>
        <p class="text-brand-cream/65 text-lg leading-relaxed">
          No assembly line. No outsourced finishing. Every Timbrcase passes through the same workshop, the same eyes, twice.
        </p>
        <div class="mt-10 aspect-[16/9] rounded-2xl overflow-hidden border border-brand-gold/10">
          <img src="/images/detail.jpg" alt="Multiplex birch lamination, close-up" class="w-full h-full object-cover" loading="lazy"/>
        </div>
      </div>

      <div class="lg:col-span-7 grid sm:grid-cols-2 gap-6">
        {steps.map((s) => (
          <div class="border-t border-brand-gold/25 pt-6 pr-2">
            <div class="text-brand-gold/70 font-display text-sm mb-3">{s.n}</div>
            <h3 class="font-display text-2xl mb-3">{s.t}</h3>
            <p class="text-brand-cream/60 text-sm leading-relaxed">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
